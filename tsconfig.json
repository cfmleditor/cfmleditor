{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2021",
		"outDir": "./out",
		"types": [
			"mocha",
			"node"
		],
		"lib": [
			"ES2019",
			"ES2021",
			"ES2022"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"noImplicitAny": false,
		"strictNullChecks": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"esModuleInterop": true,
		"resolveJsonModule": true
	},
	"exclude": [
		"node_modules",
		".vscode-test",
		".vscode-test-web"
	]
}